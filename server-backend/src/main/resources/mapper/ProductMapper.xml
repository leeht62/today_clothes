<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.server.today_clothes.domain.product.mapper.ProductMapper">

    <resultMap id="ProductResultMap" type="com.server.today_clothes.domain.product.VO.Product">
        <id property="id" column="id"/>
        <result property="sellerId" column="seller_id"/>
        <result property="name" column="name"/>
        <result property="category" column="category"/>
        <result property="purchasePrice" column="purchase_price"/>
        <result property="salePrice" column="sale_price"/>
        <result property="discountedPrice" column="discounted_price"/>
        <result property="stock" column="stock"/>
        <result property="originalImage" column="original_image"/>
        <result property="aiImage" column="ai_image"/>
        <result property="status" column="status"/>
        <result property="discountedStock" column="discounted_stock"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="save" parameterType="com.server.today_clothes.domain.product.VO.Product"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO product (seller_id, name, category, purchase_price, sale_price, stock, original_image, status)
        VALUES (#{sellerId}, #{name}, #{category}, #{purchasePrice}, #{salePrice}, #{stock}, #{originalImage}, 'ACTIVE')
    </insert>

    <select id="findById" parameterType="long" resultMap="ProductResultMap">
        SELECT * FROM product WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="ProductResultMap">
        SELECT * FROM product
        <where>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

    <select id="findAllBySellerId" parameterType="long" resultMap="ProductResultMap">
        SELECT * FROM product
        WHERE seller_id = #{sellerId}
        ORDER BY created_at DESC
    </select>

    <update id="update" parameterType="com.server.today_clothes.domain.product.VO.Product">
        UPDATE product
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="category != null">category = #{category},</if>
            <if test="salePrice != null">sale_price = #{salePrice},</if>
            <if test="discountedPrice != null">discounted_price = #{discountedPrice},</if>
            <if test="aiImage != null">ai_image = #{aiImage},</if>
            <if test="status != null">status = #{status},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <update id="updateStock">
        UPDATE product
        SET stock = stock - #{quantity}, updated_at = NOW()
        WHERE id = #{id} AND stock >= #{quantity}
    </update>

    <delete id="deleteById" parameterType="long">
        DELETE FROM product WHERE id = #{id}
    </delete>

    <update id="updateDiscountedStock">
        UPDATE product
        SET discounted_stock = #{discountedStock}, updated_at = NOW()
        WHERE id = #{id}
    </update>

    <!-- DB 안전장치: 재고 있을 때만 차감, 영향받은 row 수 반환 -->
    <update id="decreaseDiscountedStockSafe">
        UPDATE product
        SET discounted_stock = discounted_stock - 1, updated_at = NOW()
        WHERE id = #{id} AND discounted_stock > 0
    </update>


</mapper>